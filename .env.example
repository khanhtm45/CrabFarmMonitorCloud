# Copy → .env (local) hoặc App Platform → Settings → Environment Variables
# KHÔNG commit file .env có password / key thật.

# Production API: https://crabfarmmonitorcloud-uwkqk.ondigitalocean.app

# PostgreSQL — chọn MỘT trong hai cách:

# Cách 1: chuỗi đầy đủ
# DATABASE_URL=Host=ras-cloud-do-user-37760190-0.g.db.ondigitalocean.com;Port=25060;Database=defaultdb;Username=doadmin;Password=CHANGE_ME;SSL Mode=Require;Trust Server Certificate=true

# Cách 2: biến rời (App Platform) — dùng DB_* KHÔNG dùng "port" (trùng HTTP PORT)
DB_HOST=ras-cloud-do-user-37760190-0.g.db.ondigitalocean.com
DB_PORT=25060
DB_NAME=defaultdb
DB_USER=doadmin
DB_PASSWORD=CHANGE_ME
DB_SSLMODE=require

PORT=8080
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_secret
TELEMETRY_API_KEY=CHANGE_ME_edge_sync_key
DEV_ADMIN_EMAIL=admin@iras.local
DEV_ADMIN_PASSWORD=CHANGE_ME
DEFAULT_FARM_ID=11111111-1111-1111-1111-111111111111
# Local: thêm farm-02, farm-03 để admin test đổi trại trên header
DEV_SEED_EXTRA_FARMS=true

TELEMETRY_SAMPLES_ENABLED=true
TELEMETRY_SAMPLES_RETENTION_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Ảnh camera khi chưa có S3 (dev)
# UPLOAD_DIR=./data/uploads

# Tuỳ chọn: DigitalOcean Spaces
# S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=ras-hdf5
# S3_USE_SSL=true
# S3_REGION=sgp1
